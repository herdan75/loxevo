{
  "server": {
    "name": "LoxEvo",
    "port": 8080
  },
  "loxone": {
    "baseUrl": "http://192.168.1.100",
    "username": "loxone-user",
    "password": "loxone-pass",
    "dryRun": true
  },
  "rooms": {
    "wohnzimmer": {
      "label": "Wohnzimmer",
      "uuid": "replace-with-loxone-lightcontroller-uuid",
      "scenes": {
        "ambient": "1",
        "hell": "777",
        "nacht": "2",
        "aus": "778"
      }
    },
    "kueche": {
      "label": "Kueche",
      "uuid": "replace-with-loxone-lightcontroller-uuid",
      "scenes": {
        "ambient": "1",
        "hell": "777",
        "nacht": "2",
        "aus": "778"
      }
    }
  },
  "tts": {
    "enabled": false,
    "cookieFile": "/config/Node.txt",
    "amazonPage": "amazon.de",
    "alexaServiceHost": "layla.amazon.de",
    "defaultVolume": 40,
    "alarmVolume": 100,
    "ignoreZeroText": true,
    "defaultDevices": [
      "replace-with-echo-device-serial"
    ],
    "allDevices": [
      "replace-with-echo-device-serial"
    ],
    "alarmDevices": [
      "replace-with-echo-device-serial"
    ]
