{
  "server": {
    "name": "LoxEvo",
    "port": 8080
  },
  "loxone": {
    "baseUrl": "http://192.168.1.100",
    "username": "loxone-user",
    "password": "loxone-pass",
    "dryRun": true
  },
  "commands": {
    "kueche_licht_hell": {
      "label": "Kueche Licht Hell",
      "voiceName": "Kueche Licht Hell",
      "category": "Licht",
      "room": "kueche",
      "function": "licht",
      "action": "hell",
      "loxone": {
        "type": "changeTo",
        "uuid": "replace-with-loxone-lightcontroller-uuid",
        "value": "777"
      },
      "enabled": true
    },
    "rolladen_tv_auf": {
      "label": "Rollladen TV Auf",
      "voiceName": "Rollladen TV Auf",
      "category": "Rollladen",
      "room": "tv",
      "function": "rolladen",
      "action": "auf",
      "loxone": {
        "type": "direct",
        "uuid": "replace-with-loxone-shutter-uuid",
        "value": "FullUp"
      },
      "enabled": true
    },
    "lueftung_bad_ein": {
      "label": "Lueftung Bad Ein",
      "voiceName": "Lueftung Bad Ein",
      "category": "Lueftung",
      "room": "bad",
      "function": "lueftung",
      "action": "ein",
      "loxone": {
        "type": "direct",
        "uuid": "replace-with-loxone-ventilation-uuid",
        "value": "on"
      },
      "enabled": true
    },
    "roboter_stop": {
      "label": "Roboter Stop",
      "voiceName": "Roboter Stop",
      "category": "Reinigung",
      "room": "",
      "function": "roboter",
      "action": "stop",
      "loxone": {
        "type": "pulse",
        "uuid": "replace-with-loxone-robot-stop-button-uuid",
        "value": ""
      },
      "enabled": true
    },
    "roboter_kueche": {
      "label": "Roboter Kueche",
      "voiceName": "Roboter Kueche",
      "category": "Reinigung",
      "room": "kueche",
      "function": "roboter",
      "action": "reinigen",
      "loxone": {
        "type": "direct",
        "uuid": "replace-with-loxone-robot-room-selector-uuid",
        "value": "2"
      },
      "enabled": true
    }
  },
  "tts": {
    "enabled": false,
    "cookieFile": "/config/Node.txt",
    "amazonPage": "amazon.de",
    "alexaServiceHost": "layla.amazon.de",
    "defaultVolume": 40,
    "alarmVolume": 100,
    "ignoreZeroText": true,
    "defaultDevices": [
      "replace-with-echo-device-serial"
    ],
    "allDevices": [
      "replace-with-echo-device-serial"
    ],
    "alarmDevices": [
      "replace-with-echo-device-serial"
    ]
  }
}
