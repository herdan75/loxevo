{
  "server": {
    "name": "LoxEvo",
    "port": 8080
  },
  "loxone": {
    "baseUrl": "http://192.168.1.100",
    "username": "loxone-user",
    "password": "loxone-pass",
    "dryRun": true
  },
  "commands": {
    "kueche_licht_hell": {
      "label": "Kueche Licht Hell",
      "voiceName": "Kueche Licht Hell",
      "room": "kueche",
      "function": "licht",
      "action": "hell",
      "loxoneUuid": "replace-with-loxone-lightcontroller-uuid",
      "loxoneCommand": "777",
      "enabled": true
    },
    "kueche_licht_ambient": {
      "label": "Kueche Licht Ambient",
      "voiceName": "Kueche Licht Ambient",
      "room": "kueche",
      "function": "licht",
      "action": "ambient",
      "loxoneUuid": "replace-with-loxone-lightcontroller-uuid",
      "loxoneCommand": "1",
      "enabled": true
    },
    "wohnzimmer_licht_aus": {
      "label": "Wohnzimmer Licht Aus",
      "voiceName": "Wohnzimmer Licht Aus",
      "room": "wohnzimmer",
      "function": "licht",
      "action": "aus",
      "loxoneUuid": "replace-with-loxone-lightcontroller-uuid",
      "loxoneCommand": "778",
      "enabled": true
    }
  },
  "tts": {
    "enabled": false,
    "cookieFile": "/config/Node.txt",
    "amazonPage": "amazon.de",
    "alexaServiceHost": "layla.amazon.de",
    "defaultVolume": 40,
    "alarmVolume": 100,
    "ignoreZeroText": true,
    "defaultDevices": [
      "replace-with-echo-device-serial"
    ],
    "allDevices": [
      "replace-with-echo-device-serial"
    ],
    "alarmDevices": [
      "replace-with-echo-device-serial"
    ]
  }
}
